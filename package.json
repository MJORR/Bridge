{
  "name": "bridge-theme",
  "version": "1.0.0",
  "description": "Bridge — a modern WordPress block theme with a Vite build pipeline.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production",
    "preview": "vite preview",
    "lint:js": "eslint \"src/**/*.js\"",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint": "npm run lint:js && npm run lint:css",
    "format": "prettier --write \"src/**/*.{js,scss,json}\""
  },
  "dependencies": {
    "swiper": "^11.1.14"
  },
  "devDependencies": {
    "@wordpress/eslint-plugin": "^21.0.0",
    "@wordpress/stylelint-config": "^23.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "postcss": "^8.4.49",
    "postcss-preset-env": "^10.1.1",
    "prettier": "^3.3.3",
    "sass": "^1.81.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "vite": "^5.4.11"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
